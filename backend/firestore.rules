// Firestore Security Rules for Pulsechecks
// These rules are applied when using Firebase/Firestore
// Access control is handled at the application level via JWT tokens

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all access (access is controlled by backend)
    match /{document=**} {
      allow read, write: if false;
    }

    // Note: All actual access control is enforced in the backend application
    // via JWT verification and team membership checks.
    // Firestore rules are set to deny by default as an extra security layer.
  }
}
